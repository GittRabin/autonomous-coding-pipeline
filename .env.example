# Optional: only needed when PLAN_MODEL_PROVIDER=anthropic
ANTHROPIC_API_KEY=
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=yourname/yourrepo
OLLAMA_MODEL=qwen2.5-coder:1.5b
OLLAMA_PLANNER_MODEL=qwen2.5-coder:1.5b
OLLAMA_AUTO_PULL=true
OLLAMA_FALLBACK_MODEL=qwen2.5-coder:1.5b
PLAN_MODEL_PROVIDER=auto
AIDER_MODEL=ollama/qwen2.5-coder:1.5b
AIDER_EDITOR_MODEL=
AIDER_ARCHITECT=0
TARGET_BRANCH=
PIPELINE_BRANCH_MODE=issue-branch
SKIP_PR_CREATE=auto
WORK_DIR=$HOME/pipeline
REPO_DIR=$HOME/repos
REPO_PATH_OVERRIDE=
VENV_DIR=$HOME/.venv/pipeline
POLL_INTERVAL_MINUTES=5
PROJECT_NAME=default
TRIGGER_LABEL=overnight-task
PROCESSING_LABEL=processing
TASK_LABEL_CODE=task-code
TASK_LABEL_E2E=task-e2e
# Optional: set this if task-e2e should invoke a custom toolchain command
E2E_RUNNER_CMD=
